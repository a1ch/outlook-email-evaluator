# Streamlit loads secrets from THIS file when you run from the repo root:
#   copy this to .streamlit/secrets.toml  (same folder as this example)
# On Streamlit Community Cloud: paste this entire block into the app → ⚙ Settings → Secrets.

SUPABASE_URL = "https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "eyJ... paste service_role key from Supabase → Project Settings → API ..."

# Optional: UUID from  select id, name from public.organizations;
DEFAULT_ORG_ID = ""

# Optional: shared passphrase users must enter to submit
PORTAL_SIGNUP_SECRET = ""

# Optional: override links shown next to the “agree to terms” checkbox
# TERMS_URL = "https://ingot.solutions/terms"
# PRIVACY_URL = "https://github.com/a1ch/outlook-email-evaluator/blob/main/PRIVACY.md"
